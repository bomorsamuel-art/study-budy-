rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (required)
    //   - photoURL: string (optional)
    //   - isOnline: boolean (optional)
    //   - lastSeen: timestamp (optional)
    //
    // Collection: chats
    // Document ID: {chatId}
    // Fields:
    //   - participants: list of strings (required)
    //   - lastMessage: string (optional)
    //   - updatedAt: timestamp (required)
    //
    // Collection: chats/{chatId}/messages
    // Document ID: {messageId}
    // Fields:
    //   - senderId: string (required)
    //   - text: string (required)
    //   - timestamp: timestamp (required)
    //   - read: boolean (optional)
    // Collection: user_data
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - notes: string (optional)
    //   - flashcards: string (optional)
    //   - studyPlan: string (optional)
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function isValidString(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    // Domain Validators
    function isValidUser() {
      return hasRequiredFields(['uid', 'email', 'displayName']) &&
             request.resource.data.uid == request.auth.uid &&
             request.resource.data.email is string &&
             request.resource.data.displayName is string;
    }

    function isValidChat() {
      return hasRequiredFields(['participants', 'updatedAt']) &&
             request.resource.data.participants is list &&
             request.resource.data.participants.size() == 2 &&
             request.auth.uid in request.resource.data.participants &&
             request.resource.data.updatedAt is timestamp;
    }

    function isValidMessage() {
      return hasRequiredFields(['senderId', 'text', 'timestamp']) &&
             request.resource.data.senderId == request.auth.uid &&
             isValidString('text', 1, 2000) &&
             request.resource.data.timestamp is timestamp;
    }

    function isValidUserData() {
      return hasRequiredFields(['uid']) &&
             request.resource.data.uid == request.auth.uid &&
             (!('notes' in request.resource.data) || request.resource.data.notes is string) &&
             (!('flashcards' in request.resource.data) || request.resource.data.flashcards is string) &&
             (!('studyPlan' in request.resource.data) || request.resource.data.studyPlan is string);
    }

    // Users Collection
    match /users/{userId} {
      // Anyone authenticated can read user profiles (needed for chat)
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser();
      allow update: if isOwner(userId) && isValidUser();
    }

    // User Data Collection (Private)
    match /user_data/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUserData();
      allow update: if isOwner(userId) && isValidUserData();
    }

    // Chats Collection
    match /chats/{chatId} {
      // Users can only read chats they are part of
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && isValidChat();
      allow update: if isAuthenticated() && 
                    request.auth.uid in resource.data.participants &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastMessage', 'updatedAt']);
      
      // Messages Subcollection
      match /messages/{messageId} {
        // Users can read messages if they are part of the parent chat
        allow read: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isAuthenticated() && 
                      request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants &&
                      isValidMessage();
        allow update: if isAuthenticated() && 
                      request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants &&
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      }
    }
  }
}
